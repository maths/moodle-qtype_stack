<div class="qtype_stack_question_report">
    <!-- Dashboard and preview links -->

  <h2>{{question.name}}</h2>
  <p>{{#str}} version, qtype_stack {{/str}} {{question.version}}<p>

  <ul class="nav">
    <li class="nav-item" role="presentation">
      <a class="nav-link" href="{{{general.editquestionlink}}}">{{#str}} editquestioninthequestionbank, qtype_stack {{/str}}</a>
    </li>
    <li class="nav-item" role="presentation">
      <a class="nav-link" href="{{{general.editxmllink}}}">{{#str}} editxml, qtype_stack {{/str}}</a>
    </li>
    <li class="nav-item" role="presentation">
      <a class="nav-link" href="{{{general.questionbanklink}}}">{{#str}} seethisquestioninthequestionbank, qtype_stack {{/str}}</a>
    </li>
    <li class="nav-item" role="presentation">
      <a class="nav-link" href="{{{general.chatlink}}}">{{#str}} sendgeneralfeedback, qtype_stack {{/str}}</a>
    </li>
    <li class="nav-item" role="presentation">
      <a class="nav-link" href="{{{general.tidylink}}}">{{#str}} tidyquestion, qtype_stack {{/str}}</a>
    </li>
    <li class="nav-item" role="presentation">
      <a class="nav-link" href="{{{general.exportquestionlink}}}">{{#str}} exportthisquestion, qtype_stack {{/str}}</a>
    </li>
    <li class="nav-item" role="presentation">
      <a class="nav-link" href="{{{general.reportlink}}}">{{#str}} basicquestionreport, qtype_stack {{/str}}</a>
    </li>
    <li class="nav-item" role="presentation">
      <a class="nav-link" href="{{{general.todolink}}}">{{#str}} seetodolist, qtype_stack {{/str}}</a>
    </li>
    <li class="nav-item" role="presentation">
      <a class="nav-link" href="{{{general.bulktestlink}}}">{{#str}} bulktestquiz, qtype_stack {{/str}}</a>
    </li>
  </ul>

  <!-- Tab headers -->
  <ul class="nav nav-tabs" id="myTab" role="tablist">
    <li class="nav-item" role="presentation">
      <a class="nav-link active" href="#test-pane" id="test-tab" data-bs-toggle="tab" data-toggle="tab" role="tab" aria-controls="test-pane" aria-selected="true">{{#str}} tests, qtype_stack {{/str}}</a>
    </li>
    <li class="nav-item stack-dash-tab-load" role="presentation">
      <a class="nav-link stack-dash-tab-load disabled" href="#question-pane" id="question-tab" data-bs-toggle="tab" data-toggle="tab" role="tab" aria-controls="question-pane" aria-selected="false">{{#str}} question, core {{/str}}</a>
    </li>
    <li class="nav-item stack-dash-tab-load" role="presentation">
      <a class="nav-link stack-dash-tab-load disabled" href="#variants-pane" id="variants-tab" data-bs-toggle="tab" data-toggle="tab" role="tab" aria-controls="variants-pane" aria-selected="false">{{#str}} variants, qtype_stack {{/str}}</a>
    </li>
  </ul>

  <!-- Tab panes -->
  <div class="tab-content">
    <div class="tab-pane mt-3" id="question-pane" role="tabpanel" aria-labelledby="question-tab">
      <h2>{{question.name}}</h2>
      <h2>{{#str}} seed, qtype_stack {{/str}}: {{question.seed}}</h2>
      <br>
      <h3>{{#str}} questionnote, qtype_stack {{/str}}</h3>
      <div class="que"><div class="questionnote">{{{question.questionnote}}}</div></div>
      <h3>{{#str}} questionvariablevalues, qtype_stack {{/str}}</h3>
      <div class="questionvariables"><pre>{{question.questionvariablevalues}}</pre></div>
      <br>
      <h3>{{#str}} prts, qtype_stack {{/str}}</h3>
      {{#question.prts}}
        <details>
          <summary><h4 style="display:inline-block">{{name}}</h4></summary>
          <div class="questionvariables"><pre>{{prt}}</pre></div>
        </details>
      {{/question.prts}}
      <br>
      <h3>{{#str}} questionpreview, qtype_stack {{/str}}</h3>
      {{{question.renderquestion}}}
      <h3>{{#str}} generalfeedback, qtype_stack {{/str}}</h3>
      {{#question.rendergeneralfeedback}}
        <div class="que"><div class="outcome generalfeedback">{{{question.rendergeneralfeedback}}}</div></div>
      {{/question.rendergeneralfeedback}}
      {{^question.rendergeneralfeedback}}
        <br><br><br>
      {{/question.rendergeneralfeedback}}
      <h3>{{#str}} questiondescription, qtype_stack {{/str}}</h3>
      {{#question.renderquestiondescription}}
        <div class="que"><div class="outcome generalfeedback">{{{question.renderquestiondescription}}}</div></div>
      {{/question.renderquestiondescription}}
      {{#question.questiondescription}}
        <div class="que"><pre class="outcome generalfeedback">{{question.questiondescription}}</pre></div>
      {{/question.questiondescription}}
      {{^question.questiondescription}}
        <br><br><br>
      {{/question.questiondescription}}
      <p>{{question.stackversion}}</p>
    </div>
    <div class="tab-pane active mt-3" id="test-pane" role="tabpanel" aria-labelledby="test-tab">
      {{#general.testcreated}}
        <p><i class="icon fa fa-exclamation-circle text-danger fa-fw"></i>{{#str}} runquestiontests_auto, qtype_stack {{/str}}</p>
      {{/general.testcreated}}
      {{#general.canedit}}{{#tests.demotest}}
        <button class="btn btn-danger" type="button" onclick="window.location.href='{{{general.defaulttestlink}}}'">
          {{#str}} runquestiontests_autoprompt, qtype_stack {{/str}}
        </button>
      {{/tests.demotest}}{{/general.canedit}}
      {{#tests.demotest}}
        <p>{{#str}} runquestiontests_explanation, qtype_stack {{/str}}</p>
      {{/tests.demotest}}
      {{#question.upgradeerrors}}
        <p class="fail">{{question.upgradeerrors}}</p>
      {{/question.upgradeerrors}}
      {{#question.validationerrors}}
        <p class="fail">{{question.validationerrors}}</p>
      {{/question.validationerrors}}
      {{#question.tests.hasresults}}
        <h2>{{#str}} runquestiontests_autoprompt, qtype_stack {{/str}}</h2>
      {{/question.tests.hasresults}}
      {{#tests.hasheadlineerror}}
        <p class="overallresult fail">{{#str}} errors, qtype_stack {{/str}}</p>
        {{#tests.runtimeerrors}}
          <p>{{{#tests.runtimeerrors}}}</p>
        {{/tests.runtimeerrors}}
        {{#tests.generalfeedbackerror}}
          <p>{{#str}} errors, qtype_stack {{/str}}: {{tests.generalfeedbackerror}}</p>
        {{/tests.generalfeedbackerror}}
      {{/tests.hasheadlineerror}}
      {{#tests.hasinputs}}
        <h2>{{#str}} questiontestsfor, qtype_stack, {{question.seed}} {{/str}}</h2>
      {{/tests.hasinputs}}
      {{^tests.hasresults}}
        <p>
          <i class="icon fa fa-exclamation-circle text-danger fa-fw"></i>{{#str}} runquestiontests_alert, qtype_stack {{/str}}
          {{#str}} notestcasesyet, qtype_stack {{/str}}
        </p>
      {{/tests.hasresults}}
      {{#tests.hasresults}}
        {{#tests.allpassed}}
          <p class="overallresult pass">
            {{#tests.hasrandomvariants}}
              {{#str}} questiontestsfor, qtype_stack, {{question.seed}} {{/str}}:
            {{/tests.hasrandomvariants}}
            {{#str}} stackInstall_testsuite_pass, qtype_stack {{/str}}
          </p>
        {{/tests.allpassed}}
        {{^tests.allpassed}}
          <p class="overallresult fail">
            {{#tests.hasrandomvariants}}
              {{#str}} questiontestsfor, qtype_stack, {{question.seed}} {{/str}}:
            {{/tests.hasrandomvariants}}
            {{#str}} stackInstall_testsuite_fail, qtype_stack {{/str}}
          </p>
        {{/tests.allpassed}}
        <table class="generaltable stacktestsuite">
          <tr>
            <th style="text-align: left;">{{#str}} answertest_ab, qtype_stack {{/str}}</th>
            <th>{{#str}} description, qtype_stack {{/str}}</th>
            <th>{{#str}} score, qtype_stack {{/str}}</th>
            <th>{{#str}} penalty, qtype_stack {{/str}}</th>
            <th>{{#str}} answernote, qtype_stack {{/str}}</th>
          </tr>
          {{#tests.summary}}
            <tr onclick="window.location='#{{id}}'" style="cursor: pointer;">
                <td>{{number}}</td>
                <td>{{description}}</td>
                <td>
                  {{#scorepass}}
                    {{#str}} symbolicprtcorrectfeedback, qtype_stack {{/str}}
                  {{/scorepass}}
                  {{^scorepass}}
                    {{#str}} symbolicprtincorrectfeedback, qtype_stack {{/str}}
                  {{/scorepass}}
                </td>
                <td>
                  {{#penaltypass}}
                    {{#str}} symbolicprtcorrectfeedback, qtype_stack {{/str}}
                  {{/penaltypass}}
                  {{^penaltypass}}
                    {{#str}} symbolicprtincorrectfeedback, qtype_stack {{/str}}
                  {{/penaltypass}}
                </td>
                <td>
                  {{#notepass}}
                    {{#str}} symbolicprtcorrectfeedback, qtype_stack {{/str}}
                  {{/notepass}}
                  {{^notepass}}
                    {{#str}} symbolicprtincorrectfeedback, qtype_stack {{/str}}
                  {{/notepass}}
                </td>
            </tr>
          {{/tests.summary}}
        </table>
      {{/tests.hasresults}}
      {{#general.canedit}}
        <form method="get" class="switchtovariant" action="{{{tests.testeditlink}}}">
          <input type="hidden" name="courseid" value="{{general.courseid}}">
          <input type="hidden" name="questionid" value="{{general.questionid}}">
          <input type="hidden" name="seed" value="{{general.seed}}">
          <button class="btn btn-secondary" type="submit">
            {{#tests.hasresults}}
              {{#str}} addanothertestcase, qtype_stack {{/str}}
            {{/tests.hasresults}}
            {{^tests.hasresults}}
              {{#str}} addatestcase, qtype_stack {{/str}}
            {{/tests.hasresults}}
          </button>
        </form>
      {{/general.canedit}}
      {{#tests.output}}
        <br>
        <hr style="background-color: black;">
        {{{output}}}
        {{#canedit}}
            <div class="testcasebuttons">
                <button class="btn btn-secondary" type="button" onclick="window.location.href='{{{editlink}}}'">
                  {{#str}} editthistestcase, qtype_stack {{/str}}
                </button>
                <button class="btn btn-secondary" type="button" onclick="window.location.href='{{{confirmlink}}}'">
                  {{#str}} confirmthistestcase, qtype_stack {{/str}}
                </button>
                <button class="btn btn-secondary" type="button" onclick="window.location.href='{{{deletelink}}}'">
                  {{#str}} deletethistestcase, qtype_stack {{/str}}
                </button>
            </div>
        {{/canedit}}
      {{/tests.output}}






